generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Store {
  id                String    @id // ID de Tiendanube
  accessToken       String
  storeName         String?
  isActive          Boolean   @default(true)
  oneClickEnabled   Boolean   @default(false)
  oneClickText      String    @default("Comprar Ahora")
  oneClickBgColor   String    @default("#0052FF")
  oneClickTextColor String    @default("#FFFFFF")
  oneClickSize      String    @default("normal")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  products          Product[]
}

model Product {
  id              String   @id // ID de Tiendanube
  storeId         String   // FK hacia Store
  store           Store    @relation(fields: [storeId], references: [id])
  googleDriveLink String?  // El link de Drive (opcional al inicio)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
}

